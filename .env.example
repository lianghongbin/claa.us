# Copy to .env and adjust. See README.md.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,fin.skyvl.com
CSRF_TRUSTED_ORIGINS=https://fin.skyvl.com

# SQLite (default). Optional: custom path relative to project root
# SQLITE_PATH=db.sqlite3
# Docker Compose uses SQLITE_PATH=/data/db.sqlite3 (volume ./data)

# Docker / LAN access example:
# ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.10
# FINANCE_PORT=8000   # host port in docker-compose.yml

# Docker one-click install (scripts/docker-install.sh) — auto-generated on first run
# ADMIN_EMAIL=admin@localhost
# ADMIN_PASSWORD=

# Optional PostgreSQL (if POSTGRES_DB is set, SQLite is not used)
# POSTGRES_DB=finance
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# 邮件（新建用户时发送初始密码；开发环境默认控制台输出）
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@example.com
